#!/bin/bash

config_file="$HOME/.config/claudew.json"
mode="${CLAUDEW_MODE}"
settings="$HOME/.claude/settings.json"

if [[ ! -f "$config_file" ]]
then
	echo "Error: Config file not found at $config_file" >&2
	exit 1
fi

if ! command -v fzf &> /dev/null
then
	echo "Error: fzf is not installed." >&2
	exit 1
fi

if ! command -v jq &> /dev/null
then
	echo "Error: jq is not installed." >&2
	exit 1
fi

if [[ -n "$mode" ]]
then
	local full_key
	full_key=$(jq -r --arg prefix "$mode" 'keys[] | select(startswith($prefix + ":"))' "$config_file" | head -1)
	if [[ -n "$full_key" ]]
	then
		mode="$full_key"
	fi
fi

while ! jq -e --arg mode "$mode" '.[$mode]' "$config_file" &> /dev/null
do
	mode=$(jq -r 'keys[]' "$config_file" | fzf --prompt="Select Claude environment: " --height=40% --reverse)
	if [ $? -eq 130 ]; then exit 1; fi
	if [[ -z "$mode" ]]
	then
		echo "No environment selected, please try again" >&2
	elif ! jq -e --arg mode "$mode" '.[$mode]' "$config_file" &> /dev/null
	then
		echo "Mode '$mode' not found in config, please select again" >&2
		mode=""
	fi
done

if jq -e 'has("model")' "$settings" > /dev/null
then
	new_config=$(jq 'del(.model)' "$settings")
	echo "$new_config" > "$settings"
fi

while IFS='=' read -r key value
do
	export "$key=$value"
done < <(jq -r --arg mode "$mode" '.[$mode] | to_entries | .[] | "\(.key)=\(.value)"' "$config_file")

exec claude "$@"
